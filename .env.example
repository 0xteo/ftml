HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
MODEL_NAME=openai/gpt-oss-20b
DATASET_NAME=llm-bg/Tucan-BG-v1.0
LORA_R=16
LORA_ALPHA=32
LORA_DROPOUT=0.05
LEARNING_RATE=2e-4
NUM_EPOCHS=3
BATCH_SIZE=4
GRADIENT_ACCUMULATION_STEPS=4
MAX_SEQ_LENGTH=2048
USE_4BIT=true
USE_UNSLOTH=false
USE_FLASH_ATTENTION=false
USE_RSLORA=false
USE_DORA=false
USE_PACKING=false
LR_SCHEDULER_TYPE=cosine
TARGET_MODULES=all-linear
TF32=true
WARMUP_RATIO=0.03
OUTPUT_DIR=./outputs

# Experiment loop settings (for `python -m ftml experiment`)
EXPERIMENT_TIME_BUDGET=300
EXPERIMENT_MAX_RUNS=10
EXPERIMENT_MIN_IMPROVEMENT=0.01
EXPERIMENT_BRANCH_TAG=

# Evaluation settings
EVAL_NUM_SAMPLES=5

# Slack settings (for `python -m ftml serve`)
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx
SLACK_SIGNING_SECRET=
SLACK_APP_PORT=3000

# Agent settings (for `python -m ftml auto`)
AGENT_MODEL_ID=Qwen/Qwen2.5-72B-Instruct
AGENT_PROVIDER=together
AGENT_API_KEY=
AGENT_MAX_STEPS=15
AGENT_VERBOSITY=1
GPU_VRAM_GB=24.0
